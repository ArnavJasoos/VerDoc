{
  "name": "verdoc",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "env:sync": "node scripts/sync-env.mjs",
    "dev": "node scripts/sync-env.mjs && turbo run dev",
    "build": "node scripts/sync-env.mjs && turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @verdoc/db generate",
    "db:migrate": "pnpm --filter @verdoc/db migrate",
    "db:push": "pnpm --filter @verdoc/db push"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
