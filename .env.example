# Postgres connection (your local instance on :5432)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/verdoc

# Auth — generate a strong random secret for signing access JWTs
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# Public URLs (M0: web hosts tRPC itself)
NEXT_PUBLIC_APP_URL=http://localhost:3000
